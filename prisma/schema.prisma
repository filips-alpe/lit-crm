generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status     UserStatus @default(ACTIVE)
  username   String     @unique
  name       String
  bio        String?
  color      String     @default("#000000")
  avatarSeed String?

  createdProjects  Project[] @relation(name: "ProjectCreator")
  assignedProjects Project[] @relation(name: "ProjectAssignee")
  records          Record[]
  reminders        Record[]  @relation(name: "RecordRemindTo")

  @@map("lit_user")
}

model Type {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status      TypeStatus @default(ACTIVE)
  code        String     @unique
  description String?
  layout      Json?
  color       String     @default("#000000")

  records Record[]

  @@map("lit_type")
}

model Record {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status      RecordStatus @default(ACTIVE)
  date        DateTime     @default(now())
  sum         Float        @default(0)
  hours       Float        @default(0)
  totalPrice  Float        @default(0)
  startDate   DateTime?
  endDate     DateTime?
  allDay      Boolean      @default(false)
  note        String?
  footNote    String?
  idNote      String?
  projectNote String?
  typeNote    String?
  priceNote   String?
  bookNote    String?
  placeFrom   String?
  placeTo     String?

  user       User?    @relation(fields: [userId], references: [id])
  project    Project? @relation(fields: [projectId], references: [id])
  type       Type     @relation(fields: [typeId], references: [id])
  remindTo   User?    @relation(name: "RecordRemindTo", fields: [remindToId], references: [id])
  userId     String?
  projectId  String?
  typeId     String
  remindToId String?

  @@map("lit_record")
}

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status      ProjectStatus @default(ACTIVE)
  code        String        @unique
  description String?
  color       String        @default("#000000")

  creator    User?    @relation(name: "ProjectCreator", fields: [creatorId], references: [id])
  creatorId  String?
  assignee   User?    @relation(name: "ProjectAssignee", fields: [assigneeId], references: [id])
  assigneeId String?
  records    Record[]

  @@map("lit_project")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TypeStatus {
  ACTIVE
  INACTIVE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}
