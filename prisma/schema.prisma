generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  status     UserStatus @default(ACTIVE)
  username   String     @unique
  name       String
  bio        String?
  color      String     @default("#000000")
  avatarSeed String?

  createdProjects  Project[] @relation(name: "ProjectCreator")
  assignedProjects Project[] @relation(name: "ProjectAssignee")
  createdRecords   Record[]  @relation(name: "RecordCreator")
  assignedRecords  Record[]  @relation(name: "RecordAssignee")

  @@map("lit_user")
}

model Type {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  status      TypeStatus @default(ACTIVE)
  code        String     @unique
  description String?
  layout      Json?
  color       String     @default("#000000")
  iconSeed    String?

  records Record[]

  @@map("lit_type")
}

model Record {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  status      RecordStatus @default(ACTIVE)
  title       String?
  description String?
  text        String?
  note        String?
  references  String[]     @default([])
  date        DateTime?    @db.Timestamptz(3)
  start       DateTime?    @db.Timestamptz(3)
  end         DateTime?    @db.Timestamptz(3)
  allDay      Boolean?
  sum         Decimal?     @db.Decimal(12, 2)
  hours       Float?
  total       Decimal?     @db.Decimal(12, 2)
  unit        String?
  from        String?
  to          String?

  type       Type            @relation(fields: [typeId], references: [id])
  typeId     String
  creator    User?           @relation(name: "RecordCreator", fields: [creatorId], references: [id])
  creatorId  String?
  assignee   User?           @relation(name: "RecordAssignee", fields: [assigneeId], references: [id])
  assigneeId String?
  projects   ProjectRecord[]
  record     Record?         @relation("LinkedRecord", fields: [recordId], references: [id])
  recordId   String?
  records    Record[]        @relation("LinkedRecord")

  @@map("lit_record")
}

model Project {
  id        String   @id @default(cuid(2))
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  status      ProjectStatus @default(ACTIVE)
  code        String        @unique
  description String?
  color       String        @default("#000000")

  creator    User?           @relation(name: "ProjectCreator", fields: [creatorId], references: [id])
  creatorId  String?
  assignee   User?           @relation(name: "ProjectAssignee", fields: [assigneeId], references: [id])
  assigneeId String?
  records    ProjectRecord[]

  @@map("lit_project")
}

model ProjectRecord {
  project   Project @relation(fields: [projectId], references: [id])
  projectId String
  record    Record  @relation(fields: [recordId], references: [id])
  recordId  String

  @@id([projectId, recordId])
  @@map("lit_project_record")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TypeStatus {
  ACTIVE
  INACTIVE
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}
